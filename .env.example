# SQLite file path (Fly.io: mount a volume and use e.g. /data/app.db)
DATABASE_URL=./data/local.db

# --- Multiple local dev servers (different browsers / roles) ---
# Each process needs its own DATABASE_URL file, then push schema once per file:
#   npm run db:push:b    # creates ./data/local-b.db
#   npm run db:push:c    # creates ./data/local-c.db
# Then in separate terminals (no need to rebuild better-sqlite3 on every start):
#   npm run dev          # default ./data/local.db  →  http://localhost:5173
#   npm run dev:b        # ./data/local-b.db        →  http://localhost:5174
#   npm run dev:c        # ./data/local-c.db        →  http://localhost:5175
# After switching Node major versions only: npm run rebuild:sqlite

# Required in production for correct URLs (Fly: https://your-app.fly.dev)
# ORIGIN=https://your-app.fly.dev

# --- Make yourself admin (after you sign up) ---
# Run against your SQLite file (path from DATABASE_URL), e.g.:
#   sqlite3 ./data/local.db "UPDATE user SET role = 'admin' WHERE lower(email) = lower('you@example.com');"
# Or use Drizzle Studio: npm run db:studio
# Admin cannot be chosen on the sign-up form; only submitter or reviewer.
