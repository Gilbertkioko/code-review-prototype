# Turso (production / Vercel): libsql URL + token from https://turso.tech
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-token

# Local file DB (optional): plain path is normalized to file:… for libSQL
# DATABASE_URL=./data/local.db

# --- Multiple local dev servers (different browsers / roles) ---
# Each process needs its own DB file; push schema once per file:
#   npm run db:push:b
#   npm run db:push:c
# Then in separate terminals:
#   npm run dev          # default file:./data/local.db  →  http://localhost:5173
#   npm run dev:b        # file:./data/local-b.db       →  http://localhost:5174
#   npm run dev:c        # file:./data/local-c.db       →  http://localhost:5175

# Production URL (Lucia / cookies / links). Fly.io: https://your-app.fly.dev or your custom domain.
# ORIGIN=https://your-app.fly.dev

# Socket.IO: leave unset on Fly (same origin as the app). Set to 0 only if you intentionally disable the client.
# PUBLIC_REALTIME_SOCKET=0

# Server-Sent Events at `/api/realtime`: on in `npm run dev` by default; in production set to 1 for single-Node hosts
# (Render/Railway + `node server.js`). On Vercel leave unset or 0 — fan-out is not shared across serverless instances.
# PUBLIC_REALTIME_SSE=1
# PUBLIC_REALTIME_SSE=0

# --- Make yourself admin (after you sign up) ---
# Turso: use `turso db shell your-db` or Drizzle Studio against the remote DB.
# Local file: sqlite3 ./data/local.db "UPDATE user SET role = 'admin' WHERE lower(email) = lower('you@example.com');"
# Admin cannot be chosen on the sign-up form; only submitter or reviewer.
